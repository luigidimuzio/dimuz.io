---
import { Image } from "astro:assets";
import macbookMemoji from "../assets/memoji-macbook.png";
import ThemeToggle from "./ThemeToggle.astro";
---

<aside class="sidebar">
  <div class="sidebar-inner">
    <div class="sidebar-top">
      <ThemeToggle />
    </div>

    <div class="profile flex flex-col items-center">
      <div
        class="w-24 h-24 rounded-full bg-amber-400 flex items-center justify-center overflow-hidden mb-6 shadow-sm"
      >
        <Image
          class="w-[110%] h-auto translate-y-1"
          src={macbookMemoji}
          alt="Memoji of Luigi behind a MacBook"
          width={120}
          height={120}
        />
      </div>
      <h1 class="name">Luigi Di Muzio</h1>
      <p class="tagline">
        Engineer turned PM turned... whatever this is now 🤷‍♂️
      </p>
    </div>

    <!-- <div class="about">
      <p>I write code, build products and share my journey.</p>
    </div> -->

    <div class="socials">
      <a
        href="https://linkedin.com/in/dimuz"
        target="_blank"
        rel="noopener noreferrer"
        aria-label="LinkedIn"
        class="social-link"
      >
        <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"
          ><path
            d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"
          ></path></svg
        >
      </a>
      <a
        href="https://github.com/luigidimuzio"
        target="_blank"
        rel="noopener noreferrer"
        aria-label="GitHub"
        class="social-link"
      >
        <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"
          ><path
            d="M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61C4.422 18.07 3.633 17.7 3.633 17.7c-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.399 3-.405 1.02.006 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 22.092 24 17.592 24 12.297c0-6.627-5.373-12-12-12"
          ></path></svg
        >
      </a>
      <a href="mailto:luigi@dimuz.io" aria-label="Email" class="social-link">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"
          ><path
            d="M1.5 8.67v8.58a3 3 0 003 3h15a3 3 0 003-3V8.67l-8.928 5.493a3 3 0 01-3.144 0L1.5 8.67z"
          ></path><path
            d="M22.5 6.908V6.75a3 3 0 00-3-3h-15a3 3 0 00-3 3v.158l9.714 5.978a1.5 1.5 0 001.572 0L22.5 6.908z"
          ></path></svg
        >
      </a>
    </div>
  </div>
</aside>

<style>
  .sidebar {
    position: sticky;
    top: 0;
    height: 100dvh;
    width: 320px;
    min-width: 320px;
    padding: var(--gap);
    padding-right: 0;
  }

  .sidebar-inner {
    height: 100%;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 1.5rem 1.75rem 2rem;
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 2rem;
    transition:
      background-color 0.3s ease,
      border-color 0.3s ease;
  }

  .sidebar-top {
    position: absolute;
    top: 1.5rem;
    right: 1.5rem;
    z-index: 50;
  }

  .profile {
    text-align: center;
  }

  .name {
    font-size: 1.4rem;
    font-weight: 700;
    letter-spacing: -0.02em;
    margin-bottom: 0.35rem;
  }

  .tagline {
    font-size: 0.8rem;
    color: var(--text-secondary);
    font-weight: 500;
  }

  .about p {
    font-size: 0.85rem;
    line-height: 1.6;
    color: var(--text-secondary);
  }

  .socials {
    display: flex;
    justify-content: center;
    gap: 0.75rem;
  }

  .social-link {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 40px;
    height: 40px;
    border-radius: var(--radius-sm);
    background: var(--social-bg);
    border: 1px solid var(--border);
    color: var(--text-secondary);
    transition: all 0.25s ease;
  }

  .social-link:hover {
    color: var(--text);
    background: var(--social-hover-bg);
    border-color: var(--border-hover);
    transform: translateY(-2px);
  }

  @media (max-width: 860px) {
    .sidebar {
      position: relative;
      height: auto;
      width: 100%;
      min-width: unset;
      padding: var(--gap);
      padding-bottom: 0;
    }

    .sidebar-inner {
      padding: 1.5rem 1.75rem;
    }
  }
</style>
