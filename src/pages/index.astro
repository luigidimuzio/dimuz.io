---
import MainLayout from "../layouts/MainLayout.astro";
import Sidebar from "../components/Sidebar.astro";
import Widget from "../components/Widget.astro";
import Arrow from "../components/Arrow.astro";
import RatingStars from "../components/RatingStars.astro";
import WebIcon from "../components/WebIcon.astro";
import Badge from "../components/Badge.astro";
import SectionHeader from "../components/SectionHeader.astro";
---

<MainLayout title="Luigi Di Muzio — Product Manager & Indie Maker">
  <div class="page max-w-[800px]">
    <Sidebar />

    <main class="grid-area">
      <!-- ═══ Pointerly ═══ -->

      <SectionHeader title="Currently Building 👇" align="center" />
      <section class="widget-section">
        <SectionHeader title="Pointerly" align="left">
          <Badge text="Live on the Mac App Store" variant="emerald" />
        </SectionHeader>
        <div class="bento-grid">
          <!-- App description -->
          <Widget colSpan={2} rowSpan={1} href="https://pointerly.app">
            <div class="flex flex-col gap-2">
              <div class="flex items-center gap-2">
                <img
                  src="/pointerly-logo.svg"
                  alt="Pointerly icon"
                  width="24"
                  height="24"
                />
                <div class="text-md font-semibold text-muted">Pointerly</div>
              </div>
              <div>
                <p class="text-sm text-subtle">
                  Pointerly is a macOS utility that enhances your presentations
                  by adding a laser pointer, spotlight, and other visual aids to
                  your cursor.
                </p>
              </div>
            </div>
          </Widget>

          <!-- Comet animation -->
          <Widget colSpan={2} rowSpan={1} flush>
            <div class="media-fill">
              <img
                src="/comet.gif"
                alt="Pointerly comet highlighter style in action"
                loading="lazy"
              />
            </div>
          </Widget>

          <!-- Spotlight animation -->
          <Widget colSpan={1} rowSpan={1} flush>
            <div class="media-fill">
              <img
                src="/raffaello.gif"
                alt="Pointerly spotlight highlighting in action on macOS"
                loading="lazy"
              />
            </div>
          </Widget>

          <!-- Tagline -->
          <Widget colSpan={1} rowSpan={1}>
            <div class="flex gap-4 items-center">
              <div>
                <p class="text-md text-muted">
                  Point. Highlight. Guide your audience.
                </p>
              </div>
            </div>
          </Widget>

          <!-- App Store Rating -->
          <Widget>
            <div class="flex flex-col items-center justify-center h-full gap-1">
              <div class="text-[10px] font-medium text-muted uppercase">
                13 ratings
              </div>
              <h4 class="text-2xl font-bold">4.4</h4>
              <RatingStars rating={4.4} size={12} />
            </div>
          </Widget>

          <!-- App Store Link -->
          <Widget
            href="https://apps.apple.com/app/pointerly/id6741108220"
            flush
          >
            <div class="flex flex-col justify-start h-full p-6 gap-2">
              <div class="">
                <img
                  src="/appstore-icon.png"
                  alt="AppStore Icon"
                  width="24"
                  height="24"
                />
              </div>
              <div class="identity-content flex flex-col gap-1">
                <div class="flex gap-2 items-start">
                  <h4 class="identity-headline">View on the App Store</h4>
                  <Arrow size={16} />
                </div>
                <p class="identity-caption">apps.apple.com</p>
              </div>
            </div>
          </Widget>
        </div>
        <div class="section-footer">
          <div class="footer-links">
            <a href="https://pointerly.app" target="_blank" class="footer-link">
              Check the Website <Arrow size={10} />
            </a>
            <a
              href="https://pointerly.app/build-in-public"
              target="_blank"
              class="footer-link"
            >
              Read the Product Log <Arrow size={10} />
            </a>
          </div>
        </div>
      </section>

      <section class="widget-section">
        <SectionHeader title="DalSegno" align="left">
          <Badge text="Now in Private Beta" variant="amber" />
        </SectionHeader>
        <div class="bento-grid">
          <!-- App description -->
          <Widget colSpan={2} rowSpan={1}>
            <div class="flex flex-col gap-2">
              <div class="flex items-center gap-2">
                <img
                  src="/dslogo.jpg"
                  alt="DalSegno icon"
                  width="24"
                  height="24"
                />
                <div class="text-md font-semibold text-muted">DalSegno</div>
              </div>
              <div>
                <p class="text-sm text-subtle">
                  DalSegno is a platform for music teachers, a unified place to
                  manage their schedule, students, lessons and homeworks.
                </p>
              </div>
            </div>
          </Widget>

          <!-- Early Adopters -->
          <Widget>
            <div class="flex flex-col items-center justify-center h-full gap-1">
              <div class="text-[10px] font-medium text-muted uppercase">
                Teachers in the beta
              </div>
              <h4 class="text-2xl font-bold">5</h4>
              <div class="text-xs text-subtle">with 170 students in total</div>
            </div>
          </Widget>

          <!-- App Store Rating -->
          <Widget>
            <div class="flex flex-col items-center justify-center h-full gap-1">
              <div class="text-[10px] font-medium text-muted uppercase">
                Lessons managed
              </div>
              <h4 class="text-2xl font-bold">2500+</h4>
              <div class="text-xs text-subtle">in the first 6 months</div>
            </div>
          </Widget>
        </div>
      </section>

      <!-- ═══ Skills & Extras ═══ -->
      <section class="widget-section">
        <SectionHeader title="Expertise" align="center" />
        <div class="bento-grid">
          <Widget title="Product Skills" colSpan={2}>
            <div class="skill-tags">
              <span class="tag">Product Strategy</span>
              <span class="tag">Product Discovery</span>
              <span class="tag">A/B Testing</span>
              <span class="tag">Product Analytics</span>
              <span class="tag">Data Analysis</span>
              <span class="tag">SQL</span>
            </div>
          </Widget>

          <Widget title="Builder Skills" colSpan={2}>
            <div class="skill-tags">
              <span class="tag">Swift</span>
              <span class="tag">SwiftUI</span>
              <span class="tag">Next.js</span>
              <span class="tag">Figma</span>
              <span class="tag">Claude</span>
              <span class="tag">Antigravity</span>
              <span class="tag">v0</span>
              <span class="tag">Fly.io</span>
              <span class="tag">Supabase</span>
            </div>
          </Widget>

          <Widget title="Industry Experience" colSpan={2}>
            <div class="skill-tags">
              <span class="tag">EdTech</span>
              <span class="tag">FinTech</span>
              <span class="tag">Apps</span>
              <span class="tag">Agency work</span>
              <span class="tag">Saas</span>
            </div>
          </Widget>
        </div>
      </section>

      <footer class="footer">
        <p>&copy; {new Date().getFullYear()} Luigi Di Muzio</p>
      </footer>
    </main>
  </div>
</MainLayout>
